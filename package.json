{
  "name": "thesisync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:apk": "node build.cjs",
    "build:full": "node simple-build.cjs",
    "cap:init": "npx cap init ThesiSync com.example.thesisync --web-dir=dist",
    "android:add": "npx cap add android",
    "android:sync": "npx cap copy android && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap copy android && npx cap sync android && npx cap open android",
    "android:build-debug-cli": "npm run prepare:android && node ./scripts/build-android-debug.cjs",
    "android:build-release-cli": "npm run prepare:android && node ./scripts/build-android-release.cjs",
    "android:setup-sdk": "node ./scripts/setup-android-sdk.cjs",
    "android:build-all": "npm run setup:android && npm run android:assemble-debug",
    "generate:icons": "node ./scripts/generate-icons.cjs",
    "generate:icons:auto": "node ./scripts/generate-icons-auto.cjs",
    "prepare:android": "npm run build && npx cap copy android && node ./scripts/finalize-android.cjs",
    "setup:android": "npm run android:setup-sdk && node ./scripts/setup-android.cjs",
    "android:assemble-debug": "node ./scripts/build-android-debug.cjs",
    "android:assemble-release": "node ./scripts/build-android-release.cjs",
    "android:patch-native": "node ./scripts/patch-android-native.cjs",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/supabase-js": "^2.45.4",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite-plugin-pwa": "^1.3.0"
  }
}
